<Window x:Class="VISTA.ProyectoFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="Proyecto"
        Height="710"
        Width="1040"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackground" Color="#0B1120"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#111827"/>
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="CardBrush" Color="#182235"/>
        <SolidColorBrush x:Key="InputBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="BorderBrushDark" Color="#2B3548"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F9FAFB"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#94A3B8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#60A5FA"/>
        <SolidColorBrush x:Key="AccentStrongBrush" Color="#3B82F6"/>

        <DropShadowEffect x:Key="WindowShadow"
                          BlurRadius="32"
                          ShadowDepth="0"
                          Opacity="0.35"/>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="InputComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style x:Key="InputDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style TargetType="{x:Type primitives:DatePickerTextBox}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentStrongBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="#162033"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChipBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <!-- SCROLL FLOTANTE -->
        <Style x:Key="ScrollBarInvisibleButton" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FloatingScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Background="Transparent">
                            <Border x:Name="ThumbBody"
                                    Width="4"
                                    Margin="0,8"
                                    HorizontalAlignment="Center"
                                    Background="#64748B"
                                    CornerRadius="20"
                                    Opacity="0.92"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBody" Property="Width" Value="6"/>
                                <Setter TargetName="ThumbBody" Property="Background" Value="#93C5FD"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBody" Property="Width" Value="7"/>
                                <Setter TargetName="ThumbBody" Property="Background" Value="#BFDBFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FloatingVerticalScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="16" Background="Transparent">
                            <Border Width="2"
                                    Margin="0,10"
                                    HorizontalAlignment="Center"
                                    Background="#1E293B"
                                    CornerRadius="20"
                                    Opacity="0.45"/>

                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarInvisibleButton}"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource FloatingScrollThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarInvisibleButton}"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SLIDER MODERNO -->
        <Style x:Key="SliderTrackDecreaseStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="8"
                                Background="#3B82F6"
                                CornerRadius="4"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SliderTrackIncreaseStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="8"
                                Background="#0F172A"
                                CornerRadius="4"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernSliderThumb" TargetType="Thumb">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid>
                            <Ellipse Fill="#93C5FD"/>
                            <Ellipse Width="8" Height="8" Fill="White"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderTrackDecreaseStyle}"
                                                  Command="Slider.DecreaseLarge"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModernSliderThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderTrackIncreaseStyle}"
                                                  Command="Slider.IncreaseLarge"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="22"
            CornerRadius="28"
            Background="{StaticResource WindowBackground}"
            BorderBrush="#1E293B"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#0F172A"
                    BorderBrush="#1E293B"
                    BorderThickness="0,0,0,1"
                    CornerRadius="28,28,0,0"
                    MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid Margin="22,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="12" Height="12" Background="{StaticResource AccentBrush}" CornerRadius="6"/>
                        <TextBlock Text="Proyecto"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="—"
                                Style="{StaticResource WindowActionButtonStyle}"
                                Click="BtnMinimizarVentana_Click"/>
                        <Button Content="✕"
                                Style="{StaticResource WindowActionButtonStyle}"
                                Click="BtnCerrarVentana_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24,22,24,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.28*"/>
                    <ColumnDefinition Width="22"/>
                    <ColumnDefinition Width="0.92*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock x:Name="txtTituloVentana"
                                       Text="Nuevo proyecto"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock x:Name="txtSubtituloVentana"
                                       Text="Define la información principal del proyecto."
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="14"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#132238"
                                BorderBrush="#22415F"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="14,8"
                                VerticalAlignment="Top">
                            <TextBlock x:Name="txtModoVentana"
                                       Text="Modo creación"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </Grid>

                    <Border Grid.Row="1"
                            Style="{StaticResource CardBorderStyle}"
                            Padding="22">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="0"
                                      Margin="0">
                            <ScrollViewer.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource FloatingVerticalScrollBar}"/>
                            </ScrollViewer.Resources>

                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Información general" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Completa los datos principales del proyecto."
                                           Margin="0,6,0,20"
                                           Foreground="{StaticResource TextSecondary}"/>

                                <TextBlock Text="Nombre del proyecto" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="txtNombre"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         TextChanged="ActualizarVistaPrevia"/>

                                <TextBlock Text="Descripción" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="txtDescripcion"
                                         Height="112"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="14,12"
                                         Foreground="{StaticResource TextPrimary}"
                                         CaretBrush="White"
                                         Background="{StaticResource InputBrush}"
                                         BorderBrush="{StaticResource BorderBrushDark}"
                                         BorderThickness="1"
                                         Margin="0,0,0,16"
                                         TextChanged="ActualizarVistaPrevia"/>

                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Supervisor" Style="{StaticResource LabelStyle}"/>
                                        <ComboBox x:Name="cbSupervisor"
                                                  DisplayMemberPath="NombreCompleto"
                                                  SelectedValuePath="IdUsuario"
                                                  Style="{StaticResource InputComboStyle}"
                                                  SelectionChanged="ActualizarVistaPrevia"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Estado" Style="{StaticResource LabelStyle}"/>
                                        <ComboBox x:Name="cbEstado"
                                                  Style="{StaticResource InputComboStyle}"
                                                  SelectionChanged="ActualizarVistaPrevia">
                                            <ComboBoxItem Content="Activo"/>
                                            <ComboBoxItem Content="Pausado"/>
                                            <ComboBoxItem Content="Finalizado"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Fecha inicio" Style="{StaticResource LabelStyle}"/>
                                        <DatePicker x:Name="dpFechaInicio"
                                                    Style="{StaticResource InputDatePickerStyle}"
                                                    SelectedDateChanged="ActualizarVistaPrevia"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Fecha fin" Style="{StaticResource LabelStyle}"/>
                                        <DatePicker x:Name="dpFechaFin"
                                                    Style="{StaticResource InputDatePickerStyle}"
                                                    SelectedDateChanged="ActualizarVistaPrevia"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Progreso inicial" Style="{StaticResource LabelStyle}"/>
                                <Border Background="#10192B"
                                        BorderBrush="{StaticResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="16"
                                        Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="76"/>
                                        </Grid.ColumnDefinitions>

                                        <Slider x:Name="slProgreso"
                                                Minimum="0"
                                                Maximum="100"
                                                TickFrequency="5"
                                                IsSnapToTickEnabled="False"
                                                Value="0"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource ModernSliderStyle}"
                                                ValueChanged="slProgreso_ValueChanged"/>

                                        <Border Grid.Column="1"
                                                Margin="14,0,0,0"
                                                Background="#1E293B"
                                                BorderBrush="#334155"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Height="38">
                                            <TextBlock x:Name="txtProgresoValor"
                                                       Text="0%"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource CardBorderStyle}" Padding="22" Margin="0,68,0,0">
                        <StackPanel>
                            <TextBlock Text="Vista previa" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Así se mostrará el proyecto en el sistema."
                                       Margin="0,6,0,18"
                                       Foreground="{StaticResource TextSecondary}"/>

                            <Border Background="#10192B"
                                    BorderBrush="#283548"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="18">
                                <StackPanel>
                                    <Border Background="#1D4ED8"
                                            CornerRadius="12"
                                            Padding="12,6"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,14">
                                        <TextBlock Text="Proyecto"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>

                                    <TextBlock x:Name="txtPreviewNombre"
                                               Text="Nombre del proyecto"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}"/>

                                    <TextBlock x:Name="txtPreviewDescripcion"
                                               Text="Descripción del proyecto."
                                               Margin="0,10,0,16"
                                               Foreground="{StaticResource TextSecondary}"
                                               TextWrapping="Wrap"/>

                                    <WrapPanel Margin="0,0,0,16">
                                        <Border x:Name="bdPreviewEstado"
                                                Style="{StaticResource ChipBorderStyle}"
                                                Background="#1E3A5F">
                                            <TextBlock x:Name="txtPreviewEstado"
                                                       Text="Activo"
                                                       Foreground="#93C5FD"
                                                       FontWeight="SemiBold"/>
                                        </Border>

                                        <Border x:Name="bdPreviewSupervisor"
                                                Style="{StaticResource ChipBorderStyle}"
                                                Background="#123026">
                                            <TextBlock x:Name="txtPreviewSupervisor"
                                                       Text="Sin asignar"
                                                       Foreground="#86EFAC"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </WrapPanel>

                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="#162033"
                                                CornerRadius="14"
                                                Padding="14"
                                                Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="Inicio" Foreground="{StaticResource TextSecondary}"/>
                                                <TextBlock x:Name="txtPreviewInicio"
                                                           Text="-"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontWeight="SemiBold"
                                                           Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1"
                                                Background="#162033"
                                                CornerRadius="14"
                                                Padding="14"
                                                Margin="8,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Fin" Foreground="{StaticResource TextSecondary}"/>
                                                <TextBlock x:Name="txtPreviewFin"
                                                           Text="-"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontWeight="SemiBold"
                                                           Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <TextBlock Text="Progreso" Foreground="{StaticResource TextSecondary}"/>
                                    <ProgressBar x:Name="pbPreviewProgreso"
                                                 Height="10"
                                                 Margin="0,10,0,8"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="0"/>
                                    <TextBlock x:Name="txtPreviewProgreso"
                                               Text="0%"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Background="#10192B"
                            BorderBrush="#283548"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="16"
                            Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Tips rápidos"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="• Usa nombres cortos y fáciles de reconocer."
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock Text="• Puedes dejar supervisor sin asignar por ahora."
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock Text="• Define fechas realistas para que el seguimiento sea claro."
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="2"
                    Background="#0F172A"
                    BorderBrush="#1E293B"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,28,28">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="24,18,24,18">
                    <Button Content="Cancelar"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="BtnCancelar_Click"/>
                    <Button x:Name="btnGuardar"
                            Content="Guardar proyecto"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="BtnGuardar_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>