<Window x:Class="VISTA.EmpresaFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración de Empresa"
        Height="700"
        Width="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackground" Color="#0B1120"/>
        <SolidColorBrush x:Key="CardBrush" Color="#182235"/>
        <SolidColorBrush x:Key="InputBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="BorderBrushDark" Color="#2B3548"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F9FAFB"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#94A3B8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#60A5FA"/>
        <SolidColorBrush x:Key="AccentStrongBrush" Color="#3B82F6"/>

        <DropShadowEffect x:Key="WindowShadow"
                          BlurRadius="32"
                          ShadowDepth="0"
                          Opacity="0.35"/>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentStrongBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="22"
            CornerRadius="28"
            Background="{StaticResource WindowBackground}"
            BorderBrush="#1E293B"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#0F172A"
                    BorderBrush="#1E293B"
                    BorderThickness="0,0,0,1"
                    CornerRadius="28,28,0,0"
                    MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid Margin="22,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="12" Height="12" Background="{StaticResource AccentBrush}" CornerRadius="6"/>
                        <TextBlock Text="Configuración"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="✕"
                                Width="34" Height="34"
                                Background="#162033"
                                Foreground="{StaticResource TextPrimary}"
                                BorderBrush="{StaticResource BorderBrushDark}"
                                BorderThickness="1"
                                Cursor="Hand"
                                Click="BtnCerrarVentana_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24,22,24,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,18">
                    <TextBlock x:Name="txtTituloVentana"
                               Text="Datos de la empresa"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Define la información principal de la compañía."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="14"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,10">
                    <Border Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="22">
                        <StackPanel>
                            <TextBlock Text="Nombre comercial" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="txtNombre" Style="{StaticResource InputTextBoxStyle}"/>

                            <TextBlock Text="Descripción" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="txtDescripcion"
                                     Height="80"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="14,12"
                                     Foreground="{StaticResource TextPrimary}"
                                     CaretBrush="White"
                                     Background="{StaticResource InputBrush}"
                                     BorderBrush="{StaticResource BorderBrushDark}"
                                     BorderThickness="1"
                                     Margin="0,0,0,16"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="NIT / Identificación" Style="{StaticResource LabelStyle}"/>
                                    <TextBox x:Name="txtNit" Style="{StaticResource InputTextBoxStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Teléfono" Style="{StaticResource LabelStyle}"/>
                                    <TextBox x:Name="txtTelefono" Style="{StaticResource InputTextBoxStyle}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Correo electrónico" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="txtCorreo" Style="{StaticResource InputTextBoxStyle}"/>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="2"
                    Background="#0F172A"
                    BorderBrush="#1E293B"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,28,28">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="24,18,24,18">
                    <Button Content="Cancelar"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="BtnCancelar_Click"/>
                    <Button x:Name="btnGuardar"
                            Content="Guardar configuración"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="BtnGuardar_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
