<Window x:Class="VISTA.UsuariosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestión de Usuarios" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F3F4F6">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Usuarios" FontSize="24" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
            
            <TextBox x:Name="txtBuscar" Grid.Column="1" Height="36" Margin="20,0,20,0"
                     Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#D1D5DB"
                     Text="Buscar por nombre o correo..." Foreground="#9CA3AF"
                     GotFocus="TxtBuscar_GotFocus" LostFocus="TxtBuscar_LostFocus" TextChanged="TxtBuscar_TextChanged"/>
            
            <Button Grid.Column="2" Content="+ Nuevo usuario" Height="36" Width="130"
                    Background="#2563EB" Foreground="White" FontWeight="SemiBold" BorderThickness="0"
                    Cursor="Hand" Click="BtnNuevo_Click"/>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1">
            <DataGrid x:Name="dgUsuarios" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      Background="White" RowBackground="White" AlternatingRowBackground="#F9FAFB"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      BorderThickness="0" Margin="10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="150"/>
                    <DataGridTextColumn Header="Apellido" Binding="{Binding Apellido}" Width="150"/>
                    <DataGridTextColumn Header="Correo" Binding="{Binding Email}" Width="200"/>
                    <DataGridTextColumn Header="Rol" Binding="{Binding RolDisplay}" Width="100"/>
                    <DataGridTextColumn Header="Nivel" Binding="{Binding NivelJerarquico}" Width="60"/>
                    <DataGridTextColumn Header="Superior Directo" Binding="{Binding NombreSuperior}" Width="150"/>
                    <DataGridTextColumn Header="Estado" Binding="{Binding EstadoDisplay}" Width="80"/>
                    <DataGridTemplateColumn Header="Acciones" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Editar" Margin="0,0,5,0" Padding="8,4" Background="#DBEAFE" Foreground="#1D4ED8" BorderThickness="0" Click="BtnEditar_Click"/>
                                    <Button Content="Desactivar" Margin="0,0,5,0" Padding="8,4" Background="#FEE2E2" Foreground="#B91C1C" BorderThickness="0" Visibility="{Binding PuedeDesactivar, Converter={StaticResource BooleanToVisibilityConverter}}" Click="BtnDesactivar_Click"/>
                                    <Button Content="Reactivar" Padding="8,4" Background="#D1FAE5" Foreground="#065F46" BorderThickness="0" Visibility="{Binding PuedeReactivar, Converter={StaticResource BooleanToVisibilityConverter}}" Click="BtnReactivar_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
