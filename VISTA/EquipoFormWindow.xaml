<Window x:Class="VISTA.EquipoFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Equipo"
        Height="650"
        Width="950"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,14">
            <TextBlock x:Name="txtTituloVentana"
                       Text="Nuevo equipo"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Bold"/>
            <TextBlock x:Name="txtSubtituloVentana"
                       Text="Crea un equipo y agrega trabajadores por correo."
                       Foreground="#94A3B8"
                       FontSize="13"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#111827"
                    CornerRadius="12"
                    Padding="18"
                    Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Nombre del equipo" Foreground="White"/>
                    <TextBox x:Name="txtNombre" Height="36" Margin="0,6,0,14"/>

                    <TextBlock Text="Descripción" Foreground="White"/>
                    <TextBox x:Name="txtDescripcion"
                             Height="80"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Margin="0,6,0,14"/>

                    <TextBlock Text="Supervisor asignado" Foreground="White"/>
                    <TextBox x:Name="txtSupervisor"
                             Height="36"
                             IsReadOnly="True"
                             Margin="0,6,0,14"/>

                    <TextBlock Text="Agregar trabajador por Gmail" Foreground="White"/>
                    <DockPanel Margin="0,6,0,10">
                        <TextBox x:Name="txtCorreoTrabajador"
                                 Height="36"
                                 Width="260"
                                 Margin="0,0,8,0"/>
                        <Button Content="Agregar"
                                Width="100"
                                Click="BtnAgregarCorreo_Click"/>
                    </DockPanel>

                    <Button Content="Quitar seleccionado"
                            Width="160"
                            Height="34"
                            Margin="0,0,0,10"
                            Click="BtnQuitarSeleccionado_Click"/>

                    <DataGrid x:Name="dgMiembros"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Height="250">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nombre" Binding="{Binding NombreCompleto}" Width="*"/>
                            <DataGridTextColumn Header="Correo" Binding="{Binding Correo}" Width="220"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="#111827"
                    CornerRadius="12"
                    Padding="18">
                <StackPanel>
                    <TextBlock Text="Resumen" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Nombre:" Foreground="#94A3B8" Margin="0,16,0,0"/>
                    <TextBlock x:Name="txtResumenNombre" Foreground="White"/>

                    <TextBlock Text="Supervisor:" Foreground="#94A3B8" Margin="0,16,0,0"/>
                    <TextBlock x:Name="txtResumenSupervisor" Foreground="White"/>

                    <TextBlock Text="Miembros:" Foreground="#94A3B8" Margin="0,16,0,0"/>
                    <TextBlock x:Name="txtCantidadMiembros" Foreground="White"/>

                    <TextBlock Text="Este equipo quedará dentro del proyecto seleccionado."
                               Foreground="#CBD5E1"
                               Margin="0,24,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancelar"
                    Width="120"
                    Height="36"
                    Margin="0,0,8,0"
                    Click="BtnCancelar_Click"/>
            <Button x:Name="btnGuardar"
                    Content="Guardar equipo"
                    Width="140"
                    Height="36"
                    Click="BtnGuardar_Click"/>
        </StackPanel>
    </Grid>
</Window>