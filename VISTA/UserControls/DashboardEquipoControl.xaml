<UserControl x:Class="VISTA.UserControls.DashboardEquipoControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <StackPanel Margin="22">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock x:Name="txtTituloEquipoSeleccionado"
                           Text="Entorno del Equipo"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#111827"
                           VerticalAlignment="Center"/>

                <Button Content="Volver al Proyecto"
                        Margin="16,0,0,0"
                        Height="36"
                        Padding="16,0"
                        Background="#FFFFFF"
                        Foreground="#374151"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="BtnVolverProyecto_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <Border Background="#F8FAFC" CornerRadius="12" Padding="14" BorderBrush="#E5E7EB" BorderThickness="1">
                <TabControl MinHeight="400">
                    <TabItem Header="Tareas">
                        <StackPanel Margin="10">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Lista de Tareas del Equipo" FontSize="16" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
                            </StackPanel>
                            <DataGrid x:Name="dgTareas"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      Height="250"
                                      Background="White"
                                      Foreground="#111827"
                                      BorderThickness="1"
                                      BorderBrush="#E5E7EB"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F9FAFB"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      ColumnHeaderHeight="40"
                                      RowHeight="40">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Título" Binding="{Binding Titulo}" Width="150"/>
                                    <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                                    <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                                    <DataGridTextColumn Header="Prioridad" Binding="{Binding Prioridad}" Width="80"/>
                                    <DataGridTextColumn Header="Límite" Binding="{Binding FechaLimite}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="Archivos">
                        <StackPanel Margin="10">
                            <TextBlock Text="Aquí irán los archivos del equipo seleccionado."/>
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="Estadísticas">
                        <StackPanel Margin="10">
                            <TextBlock Text="Aquí irán las estadísticas del equipo seleccionado."/>
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="Entorno de trabajo">
                        <StackPanel Margin="10">
                            <TextBlock Text="Aquí irán el chat y la videollamada del equipo."/>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
