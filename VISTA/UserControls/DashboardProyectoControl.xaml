<UserControl x:Class="VISTA.UserControls.DashboardProyectoControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <StackPanel Margin="22">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock x:Name="txtTituloEquipos"
                           Text="Equipos del Proyecto"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#111827"
                           VerticalAlignment="Center"/>

                <Button Content="Volver a Empresa"
                        Margin="16,0,0,0"
                        Height="36"
                        Padding="16,0"
                        Background="#FFFFFF"
                        Foreground="#374151"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="BtnVolverEmpresa_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Nuevo equipo"
                        Margin="8,0,0,0"
                        Width="120"
                        Height="36"
                        Background="#FFFFFF"
                        Foreground="#374151"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="BtnNuevoEquipo_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Editar equipo"
                        Margin="8,0,0,0"
                        Width="120"
                        Height="36"
                        Click="BtnEditarEquipo_Click"/>

                <Button Content="Eliminar equipo"
                        Margin="8,0,0,0"
                        Width="120"
                        Height="36"
                        Click="BtnEliminarEquipo_Click"/>
            </StackPanel>

            <Border Background="#F8FAFC" CornerRadius="12" Padding="14" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Lista de equipos asignados"
                               Foreground="#111827"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <DataGrid x:Name="dgEquipos"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Height="240"
                              Background="White"
                              Foreground="#111827"
                              BorderThickness="0"
                              RowBackground="White"
                              AlternatingRowBackground="#F9FAFB"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              ColumnHeaderHeight="40"
                              RowHeight="40"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Equipo" Binding="{Binding Nombre}" Width="200"/>
                            <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                            <DataGridTextColumn Header="Supervisor" Binding="{Binding Supervisor}" Width="150"/>
                            <DataGridTextColumn Header="Trabajadores" Binding="{Binding Trabajadores}" Width="90"/>
                            <DataGridTemplateColumn Header="Acciones" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="Gestionar"
                                                    Padding="10,4"
                                                    Background="#DBEAFE"
                                                    Foreground="#1D4ED8"
                                                    BorderBrush="#BFDBFE"
                                                    Cursor="Hand"
                                                    Click="BtnGestionarEquipo_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
