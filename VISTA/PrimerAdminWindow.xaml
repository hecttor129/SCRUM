<Window x:Class="VISTA.PrimerAdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración Inicial" Height="500" Width="440"
        WindowStartupLocation="CenterScreen" Background="White">
    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Crear administrador del sistema" FontSize="20" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,5"/>
            <TextBlock Text="Este paso solo ocurre una vez. Este usuario tendrá control total." FontSize="13" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,0,0,20"/>

            <TextBlock Text="Nombre" Foreground="#374151" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtNombre" Height="36" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#D1D5DB" Margin="0,0,0,12"/>

            <TextBlock Text="Apellido" Foreground="#374151" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtApellido" Height="36" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#D1D5DB" Margin="0,0,0,12"/>

            <TextBlock Text="Correo electrónico" Foreground="#374151" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtEmail" Height="36" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#D1D5DB" Margin="0,0,0,12"/>

            <TextBlock Text="Contraseña (mín. 6 caracteres)" Foreground="#374151" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="pwdPassword" Height="36" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#D1D5DB" Margin="0,0,0,12"/>

            <TextBlock Text="Confirmar contraseña" Foreground="#374151" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="pwdConfirmar" Height="36" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#D1D5DB" Margin="0,0,0,5"/>

            <TextBlock x:Name="txtError" Foreground="#EF4444" TextWrapping="Wrap" Margin="0,5,0,15" Visibility="Collapsed"/>

            <Button Content="Crear administrador" 
                    Height="40" Background="#10B981" Foreground="White" 
                    FontWeight="SemiBold" BorderThickness="0" 
                    Cursor="Hand" Click="BtnCrear_Click"/>
        </StackPanel>
    </Grid>
</Window>
