<Window x:Class="VISTA.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Iniciar sesión" Height="380" Width="420"
        WindowStartupLocation="CenterScreen" Background="White">
    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="SCRUM" FontSize="28" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="Inicia sesión para continuar" FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <TextBlock Text="Correo electrónico" Foreground="#374151" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtEmail" Height="36" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#D1D5DB" Margin="0,0,0,15"/>

            <TextBlock Text="Contraseña" Foreground="#374151" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="pwdPassword" Height="36" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#D1D5DB" Margin="0,0,0,5"/>

            <TextBlock x:Name="txtError" Foreground="#EF4444" TextWrapping="Wrap" Margin="0,5,0,15" Visibility="Collapsed"/>

            <Button Content="Iniciar sesión" 
                    Height="40" Background="#2563EB" Foreground="White" 
                    FontWeight="SemiBold" BorderThickness="0" 
                    Cursor="Hand" Click="BtnLogin_Click"/>
        </StackPanel>
    </Grid>
</Window>
